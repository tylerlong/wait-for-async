{
  "name": "wait-for-async",
  "version": "0.8.0",
  "description": "Async wait for",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/tylerlong/wait-for-async.git"
  },
  "license": "MIT",
  "types": "./dist/esm/index.d.ts",
  "module": "./dist/esm/index.js",
  "main": "./dist/cjs/index.js",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "scripts": {
    "prepublishOnly": "yarn build",
    "postpublish": "rm -rf dist",
    "build": "tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && echo '{\"type\":\"module\"}' > dist/esm/package.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "yarn-upgrade-all": "^0.8.1"
  },
  "files": [
    "dist"
  ],
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
